# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=tekros_user
DB_PASSWORD=change_me_in_production
DB_DATABASE=cotizador_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string in production: openssl rand -hex 64
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=8h

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Initial admin user (seed migration) ──────────────────────────────────────
# These values are used ONCE when the database is first initialized.
# After the first run, changing them here has no effect (migration already ran).
INITIAL_ADMIN_NOMBRE=NicoB
INITIAL_ADMIN_EMAIL=nicolas.bergmann@tekros.org
INITIAL_ADMIN_PASSWORD=change_me_in_production

# ─── Production only ──────────────────────────────────────────────────────────
# FRONTEND_PORT=80
