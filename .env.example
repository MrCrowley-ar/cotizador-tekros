# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=tekros_user
DB_PASSWORD=change_me_in_production
DB_DATABASE=cotizador_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
